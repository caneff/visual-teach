{
  "name": "visual-teach",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "docker:regen-baselines": "docker run --rm -v \"$(pwd):/work\" -w /work mcr.microsoft.com/playwright:v1.61.1-jammy rm -rf test-results playwright-report && docker run --rm --user \"$(id -u):$(id -g)\" -v \"$(pwd):/work\" -w /work mcr.microsoft.com/playwright:v1.61.1-jammy npm run test:visual:update",
    "showcase": "node scripts/showcase.js",
    "serve": "python3 -m http.server 8000",
    "lint": "eslint . && npm run lint:css",
    "lint:css": "stylelint 'assets/**/*.css'",
    "format": "prettier --write .",
    "typecheck": "tsc -p .sandcastle/tsconfig.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.0",
    "axe-playwright": "^2.2.2",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "stylelint": "^16.26.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  },
  "type": "module"
}
