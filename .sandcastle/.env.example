# Claude Code OAuth token — get one by running `claude setup-token` on your host.
# Lets the agent use your Claude subscription instead of an API key.
CLAUDE_CODE_OAUTH_TOKEN=
# Or use an Anthropic API key instead — uncomment and fill in:
# ANTHROPIC_API_KEY=
# GitHub personal access token — the agent uses it to read and manage GitHub Issues
# Create a fine-grained token: https://github.com/settings/personal-access-tokens/new
# Required repository permissions: Issues (Read and write) and Metadata (Read)
GH_TOKEN=
# Cloudflare R2 — hosts before/after visual-proof screenshots on a durable public
# CDN URL (the correct tool; replaces the old GitHub-release-asset hack).
# One-time setup:
#  1. Create an R2 bucket (e.g. visual-proof) in the Cloudflare dashboard.
#  2. Enable its "Public Development URL" -> copy the https://pub-<hash>.r2.dev base.
#  3. Create an R2 API token scoped "Object Read & Write" to that bucket; copy
#     the token value and your Account ID.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET=
R2_PUBLIC_BASE=
# --- Sandcastle bot identity (optional) ---
# When these are set, commits/PRs/comments are attributed to the bot GitHub App
# instead of your personal account. Unset = falls back to GH_TOKEN above.
# One-time setup: see .sandcastle/bot-setup.md
# Numeric App ID shown on the App's settings page.
GITHUB_APP_ID=
# RSA private key (.pem) generated when the App was created. Paste the full PEM
# with real newlines inside double quotes, OR one line with \n in place of newlines:
#   GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#   MII...
#   -----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=
# Installation ID — the trailing number at
# https://github.com/settings/installations/<INSTALLATION_ID>
GITHUB_APP_INSTALLATION_ID=
# Commit author shown in GitHub (token alone does not set these):
SANDCASTLE_BOT_GIT_NAME=
SANDCASTLE_BOT_GIT_EMAIL=
