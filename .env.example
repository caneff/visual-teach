# GitHub App credentials for Sandcastle bot identity.
# See .sandcastle/bot-setup.md for one-time setup instructions.
# Copy to .env and fill in real values; never commit .env.

# Numeric App ID shown on the App's settings page.
GITHUB_APP_ID=

# RSA private key generated when the App was created.
# Paste the full PEM, replacing real newlines with \n so it fits one line,
# OR keep real newlines inside double quotes:
#   GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
#   MII...
#   -----END RSA PRIVATE KEY-----"
GITHUB_APP_PRIVATE_KEY=

# Installation ID for this specific repository.
# Find it at: https://api.github.com/repos/<owner>/<repo>/installation
# (authenticated as the App, or via: gh api /repos/<owner>/<repo>/installation --jq '.id')
GITHUB_APP_INSTALLATION_ID=
